@using PolyPilot.Models
@using Microsoft.JSInterop
@inject IJSRuntime JS
@implements IAsyncDisposable

@if (Files.Count == 0)
{
    <div class="diff-empty">No changes</div>
}
else
{
    <div class="diff-viewer">
        <div class="diff-summary-bar">
            <div class="diff-summary">
                <span class="diff-summary-title">@SummaryLabel</span>
                <span class="diff-summary-stats">
                    <span class="stat-add">+@TotalAdded</span>
                    <span class="stat-del">-@TotalRemoved</span>
                </span>
            </div>

            @if (Files.Count > 1)
            {
                <button type="button"
                        class="diff-picker-toggle"
                        @onclick="ToggleFilePicker"
                        aria-expanded="@(!_isFilePickerCollapsed)">
                    @(_isFilePickerCollapsed ? "Show files" : "Hide files")
                </button>
            }
        </div>

        @if (!_isFilePickerCollapsed || Files.Count == 1)
        {
            <div class="diff-file-picker" role="tablist" aria-label="Changed files">
                @for (var fileIdx = 0; fileIdx < Files.Count; fileIdx++)
                {
                    var listFile = Files[fileIdx];
                    var capturedIdx = fileIdx;

                    <button type="button"
                            class="diff-file-tab @(capturedIdx == _selectedFileIdx ? "selected" : "")"
                            @onclick="() => SelectFile(capturedIdx)"
                            title="@listFile.DisplayName"
                            aria-pressed="@(capturedIdx == _selectedFileIdx)">
                        <span class="diff-file-badge @listFile.StatusCssClass">@listFile.StatusLabel</span>
                        <span class="diff-file-tab-name">@listFile.DisplayName</span>
                        <span class="diff-file-tab-stats">
                            <span class="stat-add">+@listFile.AddedLineCount</span>
                            <span class="stat-del">-@listFile.RemovedLineCount</span>
                        </span>
                    </button>
                }
            </div>
        }

        @if (SelectedFile is { } selectedFile)
        {
            var selectedIdx = _selectedFileIdx;

            <div class="diff-file" @key="selectedIdx">
                <div class="diff-file-header">
                    <span class="diff-file-badge @selectedFile.StatusCssClass">@selectedFile.StatusLabel</span>
                    <span class="diff-file-name">@selectedFile.DisplayName</span>
                    <span class="diff-file-stats">
                        <span class="stat-add">+@selectedFile.AddedLineCount</span>
                        <span class="stat-del">-@selectedFile.RemovedLineCount</span>
                    </span>
                    <span class="diff-view-toggle">
                        <button class="toggle-btn @(_viewModes.GetValueOrDefault(selectedIdx, DiffViewMode.Table) == DiffViewMode.Table ? "active" : "")"
                                @onclick="() => SetViewMode(selectedIdx, DiffViewMode.Table)"
                                title="Table view">Table</button>
                        <button class="toggle-btn @(_viewModes.GetValueOrDefault(selectedIdx, DiffViewMode.Table) == DiffViewMode.Editor ? "active" : "")"
                                @onclick="() => SetViewMode(selectedIdx, DiffViewMode.Editor)"
                                title="Editor view with syntax highlighting">Editor</button>
                    </span>
                </div>

                @if (selectedFile.Hunks.Count == 0)
                {
                    <div class="diff-empty-body">No diff hunks available for this file.</div>
                }
                else if (_viewModes.GetValueOrDefault(selectedIdx, DiffViewMode.Table) == DiffViewMode.Editor)
                {
                    <div class="diff-cm-container" id="cm-diff-@_instancePrefix-@selectedIdx"></div>
                }
                else
                {
                    <div class="diff-panes">
                        <table class="diff-table">
                            <colgroup>
                                <col class="diff-col-ln" />
                                <col class="diff-col-code" />
                                <col class="diff-col-ln" />
                                <col class="diff-col-code" />
                            </colgroup>
                            @foreach (var hunk in selectedFile.Hunks)
                            {
                                @if (!string.IsNullOrEmpty(hunk.Header))
                                {
                                    <tr class="diff-hunk-header">
                                        <td colspan="4" class="hunk-label">@hunk.Header</td>
                                    </tr>
                                }
                                @foreach (var row in DiffParser.PairLines(hunk))
                                {
                                    <tr class="diff-row">
                                        <td class="diff-ln @(row.Left?.Type == DiffLineType.Removed ? "ln-del" : "")">@(row.Left?.OldLineNo?.ToString() ?? "")</td>
                                        <td class="diff-code @(row.Left == null ? "diff-blank" : row.Left.Type == DiffLineType.Removed ? "diff-del" : "diff-ctx")"><pre>@(row.Left?.Content ?? "")</pre></td>
                                        <td class="diff-ln @(row.Right?.Type == DiffLineType.Added ? "ln-add" : "")">@(row.Right?.NewLineNo?.ToString() ?? "")</td>
                                        <td class="diff-code @(row.Right == null ? "diff-blank" : row.Right.Type == DiffLineType.Added ? "diff-add" : "diff-ctx")"><pre>@(row.Right?.Content ?? "")</pre></td>
                                    </tr>
                                }
                            }
                        </table>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public string RawDiff { get; set; } = "";
    private List<DiffFile> Files { get; set; } = new();
    private string? _lastRawDiff;
    private readonly Dictionary<int, DiffViewMode> _viewModes = new();
    private readonly Dictionary<int, int> _cmInstances = new();
    private readonly HashSet<int> _pendingEditorInit = new();
    private readonly string _instancePrefix = Guid.NewGuid().ToString("N")[..8];
    private int _generation;
    private int _selectedFileIdx;
    private bool _isFilePickerCollapsed;
    private bool _disposed;

    private DiffFile? SelectedFile =>
        _selectedFileIdx >= 0 && _selectedFileIdx < Files.Count ? Files[_selectedFileIdx] : null;

    private int TotalAdded => Files.Sum(file => file.AddedLineCount);
    private int TotalRemoved => Files.Sum(file => file.RemovedLineCount);
    private string SummaryLabel => Files.Count == 1 ? "1 file changed" : $"{Files.Count} files changed";

    private enum DiffViewMode { Table, Editor }

    protected override void OnParametersSet()
    {
        if (RawDiff != _lastRawDiff)
        {
            _lastRawDiff = RawDiff;
            Files = DiffParser.Parse(RawDiff);
            _generation++;
            _selectedFileIdx = Files.Count > 0 ? 0 : -1;
            _isFilePickerCollapsed = false;

            // Snapshot IDs before clearing so fire-and-forget only disposes these exact instances
            var idsToDispose = _cmInstances.Values.ToArray();
            _viewModes.Clear();
            _cmInstances.Clear();
            _pendingEditorInit.Clear();

            _ = DisposeJsInstancesByIdAsync(idsToDispose);
        }
    }

    private void ToggleFilePicker() => _isFilePickerCollapsed = !_isFilePickerCollapsed;

    private void SelectFile(int fileIdx)
    {
        if (fileIdx < 0 || fileIdx >= Files.Count || fileIdx == _selectedFileIdx)
            return;

        DisposeEditorInstance(_selectedFileIdx);
        _selectedFileIdx = fileIdx;

        if (_viewModes.GetValueOrDefault(fileIdx, DiffViewMode.Table) == DiffViewMode.Editor)
            _pendingEditorInit.Add(fileIdx);
    }

    private void SetViewMode(int fileIdx, DiffViewMode mode)
    {
        if (mode == DiffViewMode.Editor)
        {
            _viewModes[fileIdx] = mode;
            _pendingEditorInit.Add(fileIdx);
        }
        else
        {
            _viewModes[fileIdx] = mode;
            _pendingEditorInit.Remove(fileIdx);

            // Snapshot and remove before the async JS call
            if (_cmInstances.Remove(fileIdx, out var instanceId))
            {
                _ = DisposeJsInstancesByIdAsync(new[] { instanceId });
            }
        }
    }

    private void DisposeEditorInstance(int fileIdx)
    {
        if (fileIdx < 0)
            return;

        if (_cmInstances.Remove(fileIdx, out var instanceId))
            _ = DisposeJsInstancesByIdAsync(new[] { instanceId });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingEditorInit.Count > 0)
        {
            var pending = _pendingEditorInit.ToArray();
            _pendingEditorInit.Clear();

            foreach (var fileIdx in pending)
            {
                await InitCodeMirrorForFile(fileIdx);
            }
        }
    }

    private async Task InitCodeMirrorForFile(int fileIdx)
    {
        if (fileIdx >= Files.Count) return;

        // Double-init guard: if an instance already exists for this file, skip
        if (_cmInstances.ContainsKey(fileIdx)) return;

        var gen = _generation;
        var file = Files[fileIdx];
        var containerId = $"cm-diff-{_instancePrefix}-{fileIdx}";
        var original = DiffParser.ReconstructOriginal(file);
        var modified = DiffParser.ReconstructModified(file);

        try
        {
            var instanceId = await JS.InvokeAsync<int>(
                "PolyPilotCodeMirror.createMergeView",
                containerId, original, modified, file.FileName);

            // Stale init guard: if generation changed during await, discard the orphan
            if (_generation != gen || _disposed)
            {
                try { await JS.InvokeVoidAsync("PolyPilotCodeMirror.dispose", instanceId); }
                catch (Exception ex) { Console.Error.WriteLine($"[DiffView] Failed to dispose stale CM instance {instanceId}: {ex.Message}"); }
                return;
            }

            if (instanceId >= 0)
                _cmInstances[fileIdx] = instanceId;
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[DiffView] Failed to create CM merge view for {file.FileName}: {ex.Message}");
        }
    }

    /// <summary>
    /// Disposes specific JS CodeMirror instances by their IDs. Does not touch _cmInstances dictionary.
    /// Callers must snapshot and remove IDs from _cmInstances before calling.
    /// </summary>
    private async Task DisposeJsInstancesByIdAsync(int[] instanceIds)
    {
        foreach (var instanceId in instanceIds)
        {
            try
            {
                await JS.InvokeVoidAsync("PolyPilotCodeMirror.dispose", instanceId);
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"[DiffView] Failed to dispose CM instance {instanceId}: {ex.Message}");
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_disposed) return;
        _disposed = true;

        var idsToDispose = _cmInstances.Values.ToArray();
        _cmInstances.Clear();
        await DisposeJsInstancesByIdAsync(idsToDispose);
    }
}
