@using PolyPilot.Models
@using Microsoft.JSInterop
@inject IJSRuntime JS
@implements IAsyncDisposable

@if (PlatformHelper.IsDesktop)
{
    <div class="cm-editor-wrapper">
        @if (!string.IsNullOrEmpty(FilePath))
        {
            <div class="cm-editor-header">
                <span class="cm-editor-filepath">@FilePath</span>
                @if (!string.IsNullOrEmpty(_langLabel))
                {
                    <span class="cm-editor-lang">@_langLabel</span>
                }
            </div>
        }
        @if (_loading)
        {
            <div class="cm-editor-status">⏳ Loading editor…</div>
        }
        @if (_loadError != null)
        {
            <div class="cm-editor-status cm-editor-error">⚠️ @_loadError</div>
        }
        <div id="@_elementId" class="cm-editor-host @(_loading || _loadError != null ? "cm-hidden" : "")"></div>
    </div>
}

@code {
    /// <summary>The source code to display.</summary>
    [Parameter] public string Content { get; set; } = "";

    /// <summary>File path — used for the header display and language auto-detection.</summary>
    [Parameter] public string? FilePath { get; set; }

    /// <summary>
    /// Explicit language hint (file extension without dot, e.g. "cs", "py", "js").
    /// If omitted, detected from FilePath extension.
    /// </summary>
    [Parameter] public string? Language { get; set; }

    private readonly string _elementId = $"cm-editor-{Guid.NewGuid():N}";
    private bool _loading;
    private bool _initialized;
    private string? _loadError;
    private string _langLabel = "";

    private string ResolvedLanguage =>
        Language ?? (FilePath is { Length: > 0 } fp ? System.IO.Path.GetExtension(fp).TrimStart('.') : "");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !PlatformHelper.IsDesktop) return;
        _loading = true;
        _langLabel = ResolvedLanguage;
        StateHasChanged();
        try
        {
            await JS.InvokeVoidAsync("cmInterop.initEditor", _elementId, Content, ResolvedLanguage);
            _initialized = true;
        }
        catch (Exception ex)
        {
            _loadError = ex.Message.Contains("net::") || ex.Message.Contains("Failed to fetch")
                ? "CodeMirror unavailable (internet required for editor)"
                : ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_initialized)
        {
            try { await JS.InvokeVoidAsync("cmInterop.dispose", _elementId); } catch { }
        }
    }
}
